{
  "name": "makruk-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/server/src/index.js",
    "smoke:start": "node dist/server/src/scripts/smokeStart.js",
    "test": "vitest run --config vitest.config.ts",
    "audit:puzzles": "tsx src/scripts/auditPuzzles.ts",
    "audit:puzzle-candidates": "tsx src/scripts/auditPuzzleCandidates.ts",
    "export:puzzle-sources": "tsx src/scripts/exportPuzzleSources.ts",
    "generate:puzzle-candidates": "tsx src/scripts/generatePuzzleCandidates.ts",
    "generate:selfplay": "tsx src/scripts/generateSelfPlayGames.ts",
    "generate:puzzle-loop": "tsx src/scripts/runPuzzleLoop.ts",
    "validate:puzzles": "tsx src/scripts/validatePuzzles.ts",
    "validate:puzzle-candidates": "tsx src/scripts/validatePuzzleCandidates.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@libsql/client": "^0.17.2",
    "better-auth": "^1.6.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "socket.io": "^4.8.0",
    "uuid": "^11.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "optionalDependencies": {
    "@libsql/linux-x64-gnu": "^0.5.28"
  }
}
