{
  "name": "thaichess",
  "version": "1.0.0",
  "private": true,
  "description": "Free ThaiChess platform - play with friends online",
  "scripts": {
    "render-build": "npm install --include=dev && npm run build",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "lint": "npm run lint --workspace=client && npm run lint --workspace=server",
    "lint:fix": "npm run lint:fix --workspace=client && npm run lint:fix --workspace=server",
    "test": "npm run test:client && npm run test:server",
    "test:client": "npm run test:run --workspace=client",
    "test:e2e": "npm run test:e2e --workspace=client",
    "test:server": "npm run test --workspace=server",
    "validate:puzzles": "npm run validate:puzzles --workspace=server",
    "start": "npm run start --workspace=server"
  },
  "workspaces": [
    "server",
    "client"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0"
  }
}
