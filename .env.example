# Core server
NODE_ENV=development
PORT=3000
# HOST=127.0.0.1

# Public app URL
# Use your real site URL in production. Better Auth uses this for OAuth callbacks.
SITE_URL=http://localhost:3000
# Optional aliases if your deploy platform sets them differently.
# PUBLIC_SITE_URL=https://your-domain.com
# APP_URL=https://your-domain.com
# RENDER_EXTERNAL_URL=https://your-render-host.onrender.com

# Better Auth
# Generate a long random secret. Reuse AUTH_SECRET only if you are migrating and
# want the legacy OTP flow and Better Auth to share the same secret source.
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_URL=http://localhost:3000

# Legacy email OTP fallback
# Keep AUTH_SECRET set while the old email-code fallback still exists.
AUTH_SECRET=replace_with_a_long_random_secret

# Google OAuth
# Redirect URI example:
#   http://localhost:3000/api/auth/callback/google
#   https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
# Redirect URI example:
#   http://localhost:3000/api/auth/callback/facebook
#   https://your-domain.com/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Database
# Production recommendation: keep Turso as primary.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Local SQLite fallback when Turso is not configured
DATA_DIR=./data

# Email fallback delivery via Resend
# Required only if you want the legacy email-code sign-in flow to work.
RESEND_API_KEY=
AUTH_FROM_EMAIL=ThaiChess <noreply@your-domain.com>

# Fairy-Stockfish integration
# Use one of these approaches:
# 1. Point to a local binary on the server
# 2. Point to a separate engine service
# FAIRY_STOCKFISH_BINARY_PATH=/absolute/path/to/fairy-stockfish
# FAIRY_STOCKFISH_SERVICE_URL=http://127.0.0.1:4000
FAIRY_STOCKFISH_THREADS=1
FAIRY_STOCKFISH_HASH_MB=64
